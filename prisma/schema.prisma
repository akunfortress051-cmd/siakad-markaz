generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Program {
  id                          String                @id @default(cuid())
  nama_indo                   String                @unique
  nama_arab                   String
  kkm                         Int
  kategori                    String                @default("REGULER") // "REGULER" or "TURATS"
  programMapels               ProgramMapel[]
  riwayatRecords              RiwayatSantri[]
  kelasList                   Kelas[]
  syahadahLayout              SyahadahLayout?
  sesiTambahanList            SesiTambahanProgram[]
  sesiTaqwim                  SesiTaqwim?
  tanggalTaqwimList           TanggalTaqwim[]
  pengajarSesiProgramList     PengajarSesiProgram[]
  soalTauziList               SoalTauzi[]
  pesertaTauziList            PesertaTauzi[]
  pesertaTauziRekomendasiList PesertaTauzi[]        @relation("ProgramRekomendasi")
}

model Kelas {
  id                String          @id @default(cuid())
  nama              String          @unique
  programId         String
  program           Program         @relation(fields: [programId], references: [id], onDelete: Cascade)
  riwayatRecords    RiwayatSantri[]
  waliKelas         User?           @relation("WaliKelas")
  pengajarSesiList  PengajarSesi[]
  absenPengajarList AbsenPengajar[]
  is_akbarnas_b2    Boolean         @default(false)
  jumlah_kolom_usbu Int             @default(0) // 0=normal, 1=satu kolom, 2=dua kolom
  urutan_haflah     Int             @default(0)
}

model Mapel {
  id                 String         @id @default(cuid())
  nama_indo          String
  nama_arab          String
  jumlah_tes         Int            @default(3)
  tampil_di_syahadah Boolean        @default(true)
  masuk_akumulasi    Boolean        @default(true)
  bobot              Int            @default(1)
  bobot_usbu         Int            @default(1)
  bulan_aktif        Int            @default(0) // 0=Semua Bulan, 1=Hanya Bulan 1, 2=Hanya Bulan 2
  jumlah_tes_b2      Int? // Override jumlah tes jika berada di bulan ke-2 (Contoh: Qowaid = 1)
  programMapels      ProgramMapel[]
  nilaiList          Nilai[]
}

model ProgramMapel {
  programId String
  mapelId   String
  urutan    Int
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  mapel     Mapel   @relation(fields: [mapelId], references: [id], onDelete: Cascade)

  @@id([programId, mapelId])
  @@unique([programId, urutan])
}

model SantriInternal {
  id                    String              @id
  nama                  String?
  tempat_lahir          String?
  tanggal_lahir         String?
  alamat                String?
  gender                String?
  sakan                 String?
  kamar                 String?
  nomorLemari           String?
  dufahNama             String?
  kategori              String?
  noWaSantri            String?
  kabupaten             String?
  bulanKe               Int                 @default(0)
  isAktif               Boolean             @default(true)
  isCheckedOut          Boolean             @default(false)
  lastSyncedAt          DateTime?
  riwayatRecords        RiwayatSantri[]
  pesertaTauziList      PesertaTauzi[]
  checkoutPengajuanList CheckoutPengajuan[]
}

model Dufah {
  nama     String  @id
  namaArab String?

  usbu1StartDate DateTime? @db.Date
  usbu1EndDate   DateTime? @db.Date
  usbu1Active    Boolean   @default(false)

  usbu2StartDate DateTime? @db.Date
  usbu2EndDate   DateTime? @db.Date
  usbu2Active    Boolean   @default(false)

  usbu3StartDate DateTime? @db.Date
  usbu3EndDate   DateTime? @db.Date
  usbu3Active    Boolean   @default(false)

  riwayatRecords RiwayatSantri[]
  sesiTauziList  SesiTauzi[]
}

model RiwayatSantri {
  id                    String              @id @default(cuid())
  santriId              String
  dufahNama             String
  programId             String?
  kelasId               String?
  is_tasmi              Boolean             @default(false)
  status_kelulusan      String              @default("TIDAK_LULUS")
  santri                SantriInternal      @relation(fields: [santriId], references: [id], onDelete: Cascade)
  dufah                 Dufah               @relation(fields: [dufahNama], references: [nama], onDelete: Restrict)
  program               Program?            @relation(fields: [programId], references: [id], onDelete: SetNull)
  kelas                 Kelas?              @relation(fields: [kelasId], references: [id], onDelete: SetNull)
  nilaiList             Nilai[]
  absenSakanList        AbsenSakan[]
  absenKelasList        AbsenKelas[]
  absenKegiatanList     AbsenKegiatan[]
  riwayatUsbuList       RiwayatUsbu[]
  syahadahLayout        SyahadahLayout?
  perizinanList         Perizinan[]
  jumlah_kolom_usbu     Int? // null=ikut kelas, 0=normal, 1=satu kolom, 2=dua kolom
  checkoutPengajuanList CheckoutPengajuan[]

  @@unique([santriId, dufahNama])
}

model Nilai {
  id            String        @id @default(cuid())
  riwayatId     String
  mapelId       String
  nilaiUsbu1    Float?
  nilaiUsbu2    Float?
  nilaiNihai    Float?
  nilaiAkhir    Float?
  nilaiTambahan Float         @default(0)
  riwayat       RiwayatSantri @relation(fields: [riwayatId], references: [id], onDelete: Cascade)
  mapel         Mapel         @relation(fields: [mapelId], references: [id], onDelete: Restrict)

  @@unique([riwayatId, mapelId])
}

model RiwayatUsbu {
  id            String @id @default(cuid())
  riwayatId     String
  usbu          Int
  totalHadir    Int    @default(0)
  totalIzin     Int    @default(0)
  totalSakit    Int    @default(0)
  totalAlpha    Int    @default(0)
  rataRataNilai Float?

  riwayat RiwayatSantri @relation(fields: [riwayatId], references: [id], onDelete: Cascade)

  @@unique([riwayatId, usbu])
}

model SyahadahTemplate {
  id                       Int     @id @default(autoincrement())
  tgl_cetak_indo           String
  tgl_cetak_arab           String
  tgl_mulai_indo           String?
  tgl_mulai_arab           String?
  tgl_selesai_indo         String?
  tgl_selesai_arab         String?
  nama_mudir_indo          String
  nama_mudir_arab          String
  jabatan_mudir_indo       String
  jabatan_mudir_arab       String
  teks_dufah_akbarnas_arab String?
  teks_dufah_arab          String?
  onlineLayoutData         Json?
  // Turats-specific fields
  nama_mudir_turats        String?
  jabatan_mudir_turats     String?
  tgl_cetak_turats         String?
  tgl_mulai_turats         String?
  tgl_selesai_turats       String?
}

model SyahadahLayout {
  id                       String         @id @default(cuid())
  riwayatId                String?        @unique
  programId                String?        @unique
  layoutData               Json           @default("{}")
  musyarokahLayoutData     Json?          @default("{}")
  martabahLayoutData       Json?          @default("{}")
  martabahTuratsLayoutData Json           @default("{}")
  riwayat                  RiwayatSantri? @relation(fields: [riwayatId], references: [id], onDelete: Cascade)
  program                  Program?       @relation(fields: [programId], references: [id], onDelete: Cascade)
}

enum StatusAbsen {
  HADIR
  IZIN
  SAKIT
  ALPHA
}

enum SesiKelas {
  SESI_1
  SESI_2
  SESI_3
  SESI_4
  SESI_5
  SESI_6
  SESI_7
  SESI_8
  SESI_9
  SESI_10
}

model AbsenSakan {
  id         String        @id @default(cuid())
  riwayatId  String
  tanggal    DateTime      @db.Date
  status     StatusAbsen
  keterangan String?
  riwayat    RiwayatSantri @relation(fields: [riwayatId], references: [id], onDelete: Cascade)

  @@unique([riwayatId, tanggal])
}

model AbsenKelas {
  id         String        @id @default(cuid())
  riwayatId  String
  tanggal    DateTime      @db.Date
  sesi       SesiKelas
  status     StatusAbsen
  keterangan String?
  riwayat    RiwayatSantri @relation(fields: [riwayatId], references: [id], onDelete: Cascade)

  @@unique([riwayatId, tanggal, sesi])
}

model KategoriKegiatan {
  id            String              @id @default(cuid())
  nama          String              @unique
  aktif         Boolean             @default(true)
  absenRecords  AbsenKegiatan[]
  sesiAbsenList SesiAbsenKegiatan[]
}

model AbsenKegiatan {
  id         String           @id @default(cuid())
  riwayatId  String
  kategoriId String
  tanggal    DateTime         @db.Date
  status     StatusAbsen
  keterangan String?
  riwayat    RiwayatSantri    @relation(fields: [riwayatId], references: [id], onDelete: Cascade)
  kategori   KategoriKegiatan @relation(fields: [kategoriId], references: [id], onDelete: Cascade)

  @@unique([riwayatId, kategoriId, tanggal])
}

model LokasiKegiatan {
  id        String  @id @default(cuid())
  nama      String  @unique
  latitude  Float
  longitude Float
  radius    Int     @default(50) // dalam meter
  aktif     Boolean @default(true)

  sesiLokasiList SesiAbsenLokasi[]
}

model SesiAbsenKegiatan {
  id          String   @id @default(cuid())
  kode        String   @unique
  kategoriId  String
  durasiMenit Int
  dibukaPada  DateTime @default(now())
  ditutupPada DateTime
  isClosed    Boolean  @default(false)
  createdAt   DateTime @default(now())

  kategori   KategoriKegiatan  @relation(fields: [kategoriId], references: [id], onDelete: Cascade)
  lokasiList SesiAbsenLokasi[]
}

model SesiAbsenLokasi {
  sesiId   String
  lokasiId String

  sesi   SesiAbsenKegiatan @relation(fields: [sesiId], references: [id], onDelete: Cascade)
  lokasi LokasiKegiatan    @relation(fields: [lokasiId], references: [id], onDelete: Cascade)

  @@id([sesiId, lokasiId])
}

enum TipePerulangan {
  HARIAN
  MINGGUAN
  BULANAN
}

model Agenda {
  id              String          @id @default(cuid())
  judul           String
  deskripsi       String?
  waktuMulai      DateTime
  waktuSelesai    DateTime
  isBerulang      Boolean         @default(false)
  tipePerulangan  TipePerulangan?
  batasPerulangan DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model InstagramPost {
  id           String   @id @default(cuid())
  judul        String?
  url          String
  thumbnailUrl String?
  author       String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model User {
  id           String   @id @default(cuid())
  nama         String
  username     String   @unique
  passwordHash String
  role         String
  kelasId      String?  @unique
  sakan        String?
  noHp         String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  kelas                   Kelas?                   @relation("WaliKelas", fields: [kelasId], references: [id], onDelete: SetNull)
  pengajarSesiList        PengajarSesi[]
  pengajarSesiProgramList PengajarSesiProgram[]
  absenPengajarList       AbsenPengajar[]
  absenDigantikanList     AbsenPengajar[]          @relation("PengajarDigantikan")
  reminderLogs            ReminderLog[]
  checkoutApproverConfigs CheckoutApproverConfig[]
  checkoutApprovals       CheckoutApproval[]
}

model RolePermission {
  id         String @id @default(cuid())
  role       String
  permission String

  @@unique([role, permission])
}

model PengajarSesi {
  id      String    @id @default(cuid())
  userId  String
  kelasId String
  sesi    SesiKelas

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  kelas Kelas @relation(fields: [kelasId], references: [id], onDelete: Cascade)

  @@unique([userId, kelasId, sesi])
}

model JadwalSesi {
  id             String    @id @default(cuid())
  sesi           SesiKelas @unique
  label          String
  jamBuka        String
  jamTutup       String
  toleransiMenit Int       @default(15)
  isActive       Boolean   @default(true)
}

model AbsenPengajar {
  id                   String    @id @default(cuid())
  userId               String
  kelasId              String
  sesi                 SesiKelas
  tanggal              DateTime  @db.Date
  waktuMulai           String
  waktuSelesai         String
  materi               String
  atributNametag       Boolean   @default(false)
  atributKopiah        Boolean   @default(false)
  atributBros          Boolean   @default(false)
  kecerdasan           String?
  terlambatMenit       Int?
  isBadal              Boolean   @default(false)
  isAsisten            Boolean   @default(false)
  pengajarDigantikanId String?
  pengajarDigantikan   User?     @relation("PengajarDigantikan", fields: [pengajarDigantikanId], references: [id], onDelete: SetNull)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  kelas Kelas @relation(fields: [kelasId], references: [id], onDelete: Cascade)

  @@unique([userId, tanggal, sesi, kelasId])
}

model SesiTambahanProgram {
  id             String    @id @default(cuid())
  programId      String
  sesi           SesiKelas
  jamBuka        String
  jamTutup       String
  toleransiMenit Int       @default(15)
  isActive       Boolean   @default(true)
  program        Program   @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, sesi])
}

model SesiTaqwim {
  id             String  @id @default(cuid())
  programId      String  @unique
  jamBuka        String
  jamTutup       String
  toleransiMenit Int     @default(15)
  isActive       Boolean @default(true)
  program        Program @relation(fields: [programId], references: [id], onDelete: Cascade)
}

model TanggalTaqwim {
  id        String   @id @default(cuid())
  programId String
  tanggal   DateTime @db.Date
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, tanggal])
}

model PengajarSesiProgram {
  id        String    @id @default(cuid())
  userId    String
  programId String
  sesi      SesiKelas

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId, sesi])
}

model ReminderLog {
  id      String    @id @default(cuid())
  userId  String
  tanggal DateTime  @db.Date
  sesi    SesiKelas
  sentAt  DateTime  @default(now())
  success Boolean   @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tanggal, sesi])
}

// ===== SYAHADAH ONLINE (Temporary) =====

model ProgramOnline {
  id               String   @id @default(cuid())
  namaIndo         String   @unique
  namaArab         String
  tglCetakArab     String?
  periodeAwal      String?
  periodeAkhir     String?
  periodeAwalIndo  String?
  periodeAkhirIndo String?
  createdAt        DateTime @default(now())

  syahadahList SyahadahOnline[]
}

model SyahadahOnline {
  id              String   @id @default(cuid())
  nama            String
  programOnlineId String?
  isMusyarokah    Boolean  @default(false)
  nilai           Float?
  layoutData      Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  programOnline ProgramOnline? @relation(fields: [programOnlineId], references: [id], onDelete: SetNull)
}

// ===== PERIZINAN =====

enum TipeIzin {
  HARIAN
  BERHARI_HARI
  KELUAR_PARE
}

enum StatusIzin {
  MENUNGGU
  AKTIF
  SUDAH_KEMBALI
  SELESAI
  DITOLAK
}

model Perizinan {
  id             String     @id @default(cuid())
  riwayatId      String
  tipeIzin       TipeIzin
  alasan         String
  tanggalMulai   DateTime   @db.Date
  tanggalSelesai DateTime?  @db.Date
  statusIzin     StatusIzin @default(AKTIF)
  tanggalKembali DateTime?
  nomorTasrih    String     @unique
  createdAt      DateTime   @default(now())
  createdBy      String?
  isFromPublic   Boolean    @default(false)
  batasJam       Int?
  grupTasrihId   String?
  statusAbsen    String     @default("IZIN") // "IZIN" atau "SAKIT"

  riwayat RiwayatSantri @relation(fields: [riwayatId], references: [id], onDelete: Cascade)

  @@index([riwayatId])
  @@index([tipeIzin, statusIzin])
  @@index([grupTasrihId])
}

model PengaturanPerizinan {
  id                      Int    @id @default(1)
  batasJamKeluarPare      Int    @default(12)
  batasJamAkhirKeluarPare String @default("19:00")
}

// ===== TAUZI' FUSHUL =====

model SesiTauzi {
  id        String   @id @default(cuid())
  nama      String
  dufahNama String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  dufah       Dufah          @relation(fields: [dufahNama], references: [nama])
  pesertaList PesertaTauzi[]
  soalList    SoalTauzi[]
}

model SoalTauzi {
  id          String @id @default(cuid())
  sesiTauziId String
  programId   String
  pertanyaan  String
  urutan      Int

  sesiTauzi          SesiTauzi       @relation(fields: [sesiTauziId], references: [id], onDelete: Cascade)
  program            Program         @relation(fields: [programId], references: [id], onDelete: Cascade)
  jawabanList        JawabanTauzi[]
  responseSantriList ResponseTauzi[]

  @@unique([sesiTauziId, programId, urutan])
}

model JawabanTauzi {
  id        String  @id @default(cuid())
  soalId    String
  teks      String
  isCorrect Boolean @default(false)
  urutan    Int

  soal SoalTauzi @relation(fields: [soalId], references: [id], onDelete: Cascade)
}

model PesertaTauzi {
  id                   String   @id @default(cuid())
  sesiTauziId          String
  santriId             String
  programId            String
  nilaiSyafawi         Float?
  nilaiMuqobalah       Float?
  programRekomendasiId String?
  penyimakNama         String?
  sudahUjian           Boolean  @default(false)
  createdAt            DateTime @default(now())

  sesiTauzi          SesiTauzi       @relation(fields: [sesiTauziId], references: [id], onDelete: Cascade)
  santri             SantriInternal  @relation(fields: [santriId], references: [id], onDelete: Cascade)
  program            Program         @relation(fields: [programId], references: [id])
  programRekomendasi Program?        @relation("ProgramRekomendasi", fields: [programRekomendasiId], references: [id])
  responseList       ResponseTauzi[]

  @@unique([sesiTauziId, santriId])
}

model ResponseTauzi {
  id        String  @id @default(cuid())
  pesertaId String
  soalId    String
  jawabanId String?

  peserta PesertaTauzi @relation(fields: [pesertaId], references: [id], onDelete: Cascade)
  soal    SoalTauzi    @relation(fields: [soalId], references: [id], onDelete: Cascade)

  @@unique([pesertaId, soalId])
}

// ===== CHECK OUT =====

model CheckoutApproverConfig {
  id       String  @id @default(cuid())
  kategori String  // "REGULER" atau "TURATS"
  tipe     String  @default("USER") // "USER", "WALI_KELAS", "DHOBIT_SAKAN"
  userId   String?
  label    String  // "Wali Kelas", "Keuangan", dll
  urutan   Int     @default(0) // untuk display order

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CheckoutPengajuan {
  id        String   @id @default(cuid())
  santriId  String
  riwayatId String
  alasan    String
  status    String   @default("MENUNGGU") // MENUNGGU | DISETUJUI | DIBATALKAN | DITOLAK
  createdAt DateTime @default(now())

  santri    SantriInternal     @relation(fields: [santriId], references: [id], onDelete: Cascade)
  riwayat   RiwayatSantri      @relation(fields: [riwayatId], references: [id], onDelete: Cascade)
  approvals CheckoutApproval[]
}

model CheckoutApproval {
  id          String    @id @default(cuid())
  pengajuanId String
  userId      String
  label       String // Copy dari config saat pengajuan dibuat
  status      String    @default("MENUNGGU") // MENUNGGU | DISETUJUI | DITOLAK
  catatan     String?
  respondedAt DateTime?

  pengajuan CheckoutPengajuan @relation(fields: [pengajuanId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pengajuanId, userId])
}
